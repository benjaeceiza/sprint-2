<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/styles.css">
    <title>
        <%= product.name %>
    </title>
</head>

<body>
    <%- include('../partials/header') %>

        <main class="product-detail-main">
            <% if(product) { %>

                <div class="product-detail-wrapper">

                    <nav class="product-detail-breadcrumbs">
                        <a href="/">Volver al listado</a>
                        <span class="breadcrumb-separator">></span>
                        <a href="#">
                            <%= product.categoria %>
                        </a>
                    </nav>

                    <div class="product-detail-layout">

                        <section class="product-detail-image-section">
                            <div class="product-detail-thumbnails">
                                <% product.thumbnails.forEach((thumb, index)=> { %>
                                    <img src="<%= thumb %>" alt="Miniatura <%= index + 1 %> de <%= product.name %>"
                                        class="product-detail-thumb">
                                    <% }) %>
                            </div>
                            <div class="product-detail-main-image-container">
                                <img src="<%= product.image %>" alt="<%= product.name %>"
                                    class="product-detail-main-image">
                            </div>
                        </section>

                        <section class="product-detail-info-section">

                            <div class="product-detail-info-header">
                                <h1 class="product-detail-title">
                                    <%= product.name %>
                                </h1>

                                <div class="product-detail-price-points">
                                    <span class="product-detail-price-number">
                                        $<%= product.price %>
                                    </span>
                                </div>
                            </div>

                            <form class="product-detail-action-form" action="/cart/add" method="POST">
                                <input type="hidden" name="productId" value="<%= product.id %>">
                                <button type="submit" class="product-detail-add-to-cart-btn">Agregar al
                                    Carrito</button>
                            </form>

                            <div class="product-detail-description">
                                <p>
                                    <%= product.description %>
                                </p>
                            </div>

                        </section>
                    </div>
                </div>

                <section class="product-section">
                    <h2 class="product-section-title">Te puede interesar</h2>
                    <div class="products-container">
                        <%- include('../partials/productCard', { products, categoria: product.categoria }) %>
                    </div>
                </section>

                <%- include('../partials/categories', { categorias }) %>
                    <%}%>

        </main>

        <%- include('../partials/footer') %>
</body>

</html>