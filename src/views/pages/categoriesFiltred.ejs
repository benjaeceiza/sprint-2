<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/styles.css">
    <title>
        <%= category %> | MiEcommerce
    </title>
</head>

<body>
    <%- include('../partials/header') %>
        <main>
            <%- include('../partials/categories', { categorias }) %>
            <section class="product-section">
                <h2 class="product-section-title">Nuestros productos: <%= category %> </h2>
                <div class="products-container">
                    <%- include('../partials/productCard', { products, categoria: category  ,id:null }) %>
                </div>
            </section>
        </main>

        <%- include('../partials/footer') %>
</body>

</html>