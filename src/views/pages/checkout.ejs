<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/styles.css">
    <title>Checkout | MiEcommerce</title>
</head>

<body>
    <%- include('../partials/header') %>

    <main class="checkout-main">
        <div class="checkout-wrapper">
            
            <div class="checkout-header">
                <a href="/cart" class="checkout-back-link">&larr; Volver al Carrito</a>
                <h1 class="checkout-title">Finalizar Compra</h1>
            </div>

            <form class="checkout-layout" action="/checkout/procesar" method="POST">
                
                <div class="checkout-form-section">
                    
                    <div class="checkout-card">
                        <h2 class="checkout-card-title">1. Datos de Envío</h2>
                        
                        <div class="checkout-input-row">
                            <div class="checkout-input-group">
                                <label for="nombre">Nombre</label>
                                <input type="text" id="nombre" name="nombre" placeholder="Tu nombre" required>
                            </div>
                            <div class="checkout-input-group">
                                <label for="apellido">Apellido</label>
                                <input type="text" id="apellido" name="apellido" placeholder="Tu apellido" required>
                            </div>
                        </div>

                        <div class="checkout-input-group">
                            <label for="direccion">Dirección completa</label>
                            <input type="text" id="direccion" name="direccion" placeholder="Ej: San Martín 1234, Piso 2, Dpto 4" required>
                        </div>

                        <div class="checkout-input-row">
                            <div class="checkout-input-group">
                                <label for="ciudad">Ciudad</label>
                                <input type="text" id="ciudad" name="ciudad" placeholder="Tu ciudad" required>
                            </div>
                            <div class="checkout-input-group">
                                <label for="cp">Código Postal</label>
                                <input type="text" id="cp" name="cp" placeholder="Ej: 5730" required>
                            </div>
                        </div>
                    </div>

                    <div class="checkout-card">
                        <h2 class="checkout-card-title">2. Método de Pago</h2>
                        
                        <div class="checkout-input-group">
                            <label for="tarjeta_nombre">Nombre en la tarjeta</label>
                            <input type="text" id="tarjeta_nombre" name="tarjeta_nombre" placeholder="Como aparece en la tarjeta" required>
                        </div>

                        <div class="checkout-input-group">
                            <label for="tarjeta_numero">Número de tarjeta</label>
                            <input type="text" id="tarjeta_numero" name="tarjeta_numero" placeholder="0000 0000 0000 0000" required>
                        </div>

                        <div class="checkout-input-row">
                            <div class="checkout-input-group">
                                <label for="tarjeta_vencimiento">Vencimiento</label>
                                <input type="text" id="tarjeta_vencimiento" name="tarjeta_vencimiento" placeholder="MM/AA" required>
                            </div>
                            <div class="checkout-input-group">
                                <label for="tarjeta_cvv">Código de seguridad (CVV)</label>
                                <input type="text" id="tarjeta_cvv" name="tarjeta_cvv" placeholder="123" required>
                            </div>
                        </div>
                    </div>

                </div>

                <div class="checkout-summary-section">
                    <div class="checkout-summary-card">
                        <h2 class="checkout-summary-title">Resumen de tu Pedido</h2>
                        
                        <div class="checkout-summary-items">
                            <div class="checkout-summary-item">
                                <span class="checkout-item-name">Jack Daniel's x1</span>
                                <span class="checkout-item-price">$19.900</span>
                            </div>
                            <div class="checkout-summary-item">
                                <span class="checkout-item-name">Coca Cola x2</span>
                                <span class="checkout-item-price">$1.520</span>
                            </div>
                        </div>

                        <hr class="checkout-divider">

                        <div class="checkout-summary-totals">
                            <div class="checkout-total-row">
                                <span>Subtotal</span>
                                <span>$21.420</span>
                            </div>
                            <div class="checkout-total-row">
                                <span>Envío</span>
                                <span>¡Gratis!</span>
                            </div>
                            <div class="checkout-total-row checkout-grand-total">
                                <span>Total a Pagar</span>
                                <span>$21.420</span> 
                            </div>
                        </div>

                        <button type="submit" class="checkout-submit-btn">Confirmar Compra</button>
                        
                        <div class="checkout-secure-badge">
                            🔒 Pago 100% Seguro
                        </div>
                    </div>
                </div>

            </form>
        </div>
    </main>

    <%- include('../partials/footer') %>
</body>

</html>