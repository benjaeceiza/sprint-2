<div class="not-found-main" style="flex-direction: column; gap: 50px;">
            
    <div class="not-found-container">
        <div class="not-found-icon">📦🔍</div>
        <h1 class="not-found-title">¡Ups! Producto no encontrado</h1>
        <p class="not-found-text">
            Parece que el producto que estás buscando no existe, se quedó sin stock o el enlace es incorrecto.
        </p>
        <a href="/" class="not-found-btn">Volver a la tienda</a>
    </div>

    <section class="product-section" style="width: 100%; max-width: 1000px;">
        <h2 class="product-section-title" style="text-align: center; margin-bottom: 20px;">Te puede interesar</h2>
        <div class="products-container">
            <%- include('../partials/productCard', { products: randomProducts, categoria: "all", id: null }) %>
        </div>
    </section>

</div>